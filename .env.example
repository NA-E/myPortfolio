# ── Frontend (PUBLIC — safe to expose, shipped to the browser) ──
# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Local script only (SECRET — never commit, never ship to browser) ──
# Used by `npm run new-portal` to create portals.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Base URL used when printing the portal link (your production domain)
PORTAL_BASE_URL=http://localhost:5173
